# Copy this file to .env and fill in the values.
# .env is in .gitignore and will not be committed.
#
# Optional, when using the Stitch MCP proxy:
# STITCH_API_KEY=replace-with-stitch-api-key

# FitShelf local backend / CatVTON settings.
EXPO_PUBLIC_FITSHELF_BACKEND_URL=http://127.0.0.1:8000
FITSHELF_BACKEND_HOST=0.0.0.0
FITSHELF_BACKEND_PORT=8000
FITSHELF_BACKEND_RUNTIME_DIR=ai/outputs/api
CATVTON_WIDTH=768
CATVTON_HEIGHT=1024
CATVTON_STEPS=50
CATVTON_MIXED_PRECISION=no
FITSHELF_CATVTON_COMMAND=ai/.venv-catvton/Scripts/python.exe ai/scripts/run_catvton.py --person {person} --garment {garment} --category {category} --out {out}

# Optional Supabase app config.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Backend-only Supabase secrets belong in ai/backend/.env:
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_TRYON_BUCKET=tryon-results
