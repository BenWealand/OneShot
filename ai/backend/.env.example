# Copy this file to ai/backend/.env for local backend runs.
# ai/backend/.env is ignored by git.

FITSHELF_BACKEND_HOST=0.0.0.0
FITSHELF_BACKEND_PORT=8000
FITSHELF_BACKEND_RUNTIME_DIR=ai/outputs/api
FITSHELF_CATVTON_TIMEOUT_SECONDS=900
FITSHELF_CATV2TON_TIMEOUT_SECONDS=1200
FITSHELF_TRYON_BACKEND=catvton

# CatVTON quality defaults. Use CATVTON_STEPS=1 only for a fast smoke test.
CATVTON_WIDTH=768
CATVTON_HEIGHT=1024
CATVTON_STEPS=50
CATVTON_MIXED_PRECISION=no
FITSHELF_CATVTON_COMMAND=ai/.venv-catvton/Scripts/python.exe ai/scripts/run_catvton.py --person {person} --garment {garment} --category {category} --out {out}

# Optional CatV2TON backend. Requires a separate environment and dataset-style
# conditions; see ai/CATV2TON.md before enabling.
FITSHELF_CATV2TON_COMMAND=

# Backend-only Supabase config. Do not put the service-role key in Expo env files.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_TRYON_BUCKET=tryon-results
